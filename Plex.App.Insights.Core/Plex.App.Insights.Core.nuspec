<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<metadata>
		<id>Plex.App.Insights.Core</id>
		<dependencies>
			<dependency id="Azure.Monitor.OpenTelemetry.Exporter" version="[1.8.2,)" />
			<dependency id="OpenTelemetry.Instrumentation.AspNetCore" version="[1.17.0,)" />
			<dependency id="OpenTelemetry.Instrumentation.Http" version="[1.17.0,)" />			
			<dependency id="OpenTelemetry.Instrumentation.SqlClient" version="[1.17.0,)" />			
			<dependency id="Plex.Extensions.Configuration" version="[8.0.9,)" />
		</dependencies>
		<title>Plex.App.Insights.Core</title>
		<version>8.0</version>
		<authors>Tom Lee</authors>
		<owners>Tom Lee</owners>
		<projectUrl>https://github.com/NamNguyen09/plex-app-insight</projectUrl>
		<license type="file">LICENSE.md</license>
		<requireLicenseAcceptance>true</requireLicenseAcceptance>
		<description>A .NET 8 library that provides a single-call extension method to wire up OpenTelemetry-based Application Insights telemetry (traces and metrics) for ASP.NET Core applications with cloud role naming and SQL command capture support.</description>
		<readme>README.md</readme>
		<releaseNotes>$releasenotes$</releaseNotes>
	</metadata>
	<files>
		<file src="..\LICENSE.md" target="LICENSE.md" />
		<file src="..\README.md" target="README.md" />
		<!-- Include other necessary files -->
	</files>
</package>